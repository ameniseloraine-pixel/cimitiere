# ==================================================
# CONFIGURATION - copier ce fichier en .env
# et adapter les valeurs
# ==================================================

# Django
SECRET_KEY=changez-moi-en-production-cle-secrete-longue
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de donnees PostgreSQL + PostGIS
DB_NAME=cimetiere_db
DB_USER=postgres
DB_PASSWORD=berbyloraine
DB_HOST=localhost
DB_PORT=5433

# GDAL / GEOS (Windows) - chemins vers les DLL installees
# Adapter si installees ailleurs que C:\Program Files\GDAL
GDAL_LIBRARY_PATH=C:\Program Files\GDAL\gdal312.dll
GEOS_LIBRARY_PATH=C:\Program Files\GDAL\geos_c.dll

# Email
# console = affiche dans le terminal (dev, pas d'envoi reel)
# django.core.mail.backends.smtp.EmailBackend = envoi reel
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=ameniseloraine@gmail.com
EMAIL_HOST_PASSWORD=rqvegzuzmqbycmpd
DEFAULT_FROM_EMAIL=ameniseloraine@gmail.com

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# MFA
MFA_CODE_VALIDITY_MINUTES=10

# Celery
# True = taches executees en synchrone (dev, sans Redis)
# False = taches asynchrones (prod, Redis requis)
CELERY_TASK_ALWAYS_EAGER=True
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0